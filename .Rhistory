tags_out <- file.path(dest_dir, "wildtrax_tags_for_validation_all_batches.csv")
## ------------------------------------------------------------
## 2) TARGET SPECIES
## ------------------------------------------------------------
target_species <- c("BAWW","CONW","AMRE","ALFL","AMBI","NAWA","REVI","SWSP","TEWA","SORA","WTSP") |>
