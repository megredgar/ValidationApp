## ------------------------------------------------------------
## 1) DESTINATION
## ------------------------------------------------------------
dest_dir <- "D:/BARLT Localization Project/Wildtrax_Validation_Upload"
dir.create(dest_dir, recursive = TRUE, showWarnings = FALSE)
